# Supabase — get these from your project's Settings > API page
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — only used in trusted server contexts (migrations, admin scripts).
# Never expose this in client code or commit it to git.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL — used for magic-link redirect (must match Supabase Auth > URL Configuration > Site URL)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Gemini API key — used for URL import (HTML extraction) and photo OCR.
# Get a free key at https://aistudio.google.com/app/apikey
# Add to Vercel project settings under Environment Variables (do NOT commit the real value).
GEMINI_API_KEY=your-gemini-api-key-here

# Anthropic API key — used for AI suggestions (upgrade and swap prompts via Claude Haiku).
# Get a key at https://console.anthropic.com
# Add to Vercel project settings under Environment Variables (do NOT commit the real value).
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Salt for hashing guest IP addresses in the ratings system. Stored as a salted SHA-256 hash
# so the raw IP is never persisted. Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# Add to Vercel project settings under Environment Variables (do NOT commit the real value).
RATING_IP_SALT=your-rating-ip-salt-here
