# Supabase — get these from your project's Settings > API page
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — only used in trusted server contexts (migrations, admin scripts).
# Never expose this in client code or commit it to git.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL — used for magic-link redirect (must match Supabase Auth > URL Configuration > Site URL)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
